"use client";

import { useState } from "react";

const departments = [
  { label: "Information Technology", value: "IT" },
  { label: "Human Resources", value: "HR" },
  { label: "Finance", value: "FIN" },
  { label: "Operations", value: "OPS" }
];

const userTypes = [
  { label: "Admin", value: "ADMIN" },
  { label: "Manager", value: "MANAGER" },
  { label: "Operator", value: "OPERATOR" },
  { label: "Viewer", value: "VIEWER" }
];

export default function AdminUserCreateView() {

  const [form, setForm] = useState({
    username: "",
    firstName: "",
    lastName: "",
    departmentCode: "",
    userType: "",
    default_password: ""
  });

  const [response, setResponse] = useState(null);
  const [error, setError] = useState("");
  const [loading, setLoading] = useState(false);

  const BASE_URL = process.env.NEXT_PUBLIC_API_URL;

  const handleChange = (e) => {
    setForm({
      ...form,
      [e.target.name]: e.target.value
    });
  };

  const handleSubmit = async () => {

    setLoading(true);
    setError("");
    setResponse(null);

    try {

      const res = await fetch(`${BASE_URL}/admin/users`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(form)
      });

      const data = await res.json();

      if (!res.ok) {
        setError(data.detail || "Unable to create user");
        return;
      }

      setResponse(data);

    } catch (err) {
      setError("Server connection failed");
    } finally {
      setLoading(false);
    }
  };

  const copyPassword = () => {
    navigator.clipboard.writeText(response?.temporary_password);
    alert("Temporary password copied");
  };

  return (

    <div style={pageWrapper}>

      <div style={card}>

        <div style={cardHeader}>
          <h2 style={title}>Create New User</h2>
          <p style={subtitle}>
            Create a system user and generate a temporary password.
          </p>
        </div>

        <div style={formGrid}>

          <Input label="Username" name="username" value={form.username} onChange={handleChange} />
          <Input label="First Name" name="firstName" value={form.firstName} onChange={handleChange} />

          <Input label="Last Name" name="lastName" value={form.lastName} onChange={handleChange} />

          <div style={field}>
            <label style={label}>Department</label>
            <select
              name="departmentCode"
              value={form.departmentCode}
              onChange={handleChange}
              style={input}
            >
              <option value="">Select Department</option>
              {departments.map(dep => (
                <option key={dep.value} value={dep.value}>
                  {dep.label}
                </option>
              ))}
            </select>
          </div>

          <div style={field}>
            <label style={label}>User Type</label>
            <select
              name="userType"
              value={form.userType}
              onChange={handleChange}
              style={input}
            >
              <option value="">Select User Type</option>
              {userTypes.map(type => (
                <option key={type.value} value={type.value}>
                  {type.label}
                </option>
              ))}
            </select>
          </div>

          <Input
            label="Default Password (Optional)"
            name="default_password"
            value={form.default_password}
            onChange={handleChange}
          />

        </div>

        <div style={buttonRow}>
          <button
            onClick={handleSubmit}
            disabled={loading}
            style={submitButton}
          >
            {loading ? "Creating User..." : "Create User"}
          </button>
        </div>

      </div>

      {/* SUCCESS RESULT */}

      {response && (
        <div style={successCard}>

          <h3 style={{ marginBottom: 15 }}>User Created Successfully</h3>

          <table style={table}>
            <tbody>

              <Row label="Username" value={response.username} />
              <Row label="Name" value={`${response.firstName} ${response.lastName}`} />
              <Row label="Department" value={response.departmentCode} />
              <Row label="User Type" value={response.userType} />

              <tr>
                <td style={tableLabel}>Temporary Password</td>
                <td style={tableValue}>
                  <span style={passwordText}>
                    {response.temporary_password}
                  </span>

                  <button onClick={copyPassword} style={copyButton}>
                    Copy
                  </button>

                </td>
              </tr>

            </tbody>
          </table>

          <p style={{ marginTop: 15 }}>{response.message}</p>

        </div>
      )}

      {error && (
        <div style={errorBox}>
          {typeof error === "string" ? error : JSON.stringify(error)}
        </div>
      )}

    </div>
  );
}

/* Reusable Components */

function Input({ label: lbl, name, value, onChange }) {
  return (
    <div style={field}>
      <label style={label}>{lbl}</label>
      <input
        name={name}
        value={value}
        onChange={onChange}
        style={input}
      />
    </div>
  );
}

function Row({ label: lbl, value }) {
  return (
    <tr>
      <td style={tableLabel}>{lbl}</td>
      <td style={tableValue}>{value}</td>
    </tr>
  );
}

